<?xml version="1.0"?>
<!--
/**
 * Etechflow_AbandonedCart - Declarative database schema.
 *
 * Three tables:
 *   1. etechflow_abandoned_cart         - tracked abandoned-cart snapshots
 *   2. etechflow_abandoned_cart_rule    - admin-managed sending rules
 *   3. etechflow_abandoned_cart_email_log - per-email sending log
 *
 * Performance notes:
 *   - All hot-path columns (status, abandoned_at, customer_id, customer_email,
 *     quote_id) are indexed so cron queries stay O(log n).
 *   - Cascading FKs to quote / customer_entity / store / sales_order guarantee
 *     orphan-free state without per-request cleanup logic.
 *   - VARCHAR widths are tuned for storefront emails (255) and tokens (64)
 *     to keep rows narrow.
 *
 * @category   ETechFlow
 * @package    Etechflow_AbandonedCart
 */
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- ============================================================ -->
    <!-- TABLE 1: etechflow_abandoned_cart                              -->
    <!-- ============================================================ -->
    <table name="etechflow_abandoned_cart" resource="default" engine="innodb"
           comment="ETechFlow Abandoned Cart Tracking">

        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false"
                identity="true" comment="Primary Key"/>

        <column xsi:type="int" name="quote_id" unsigned="true" nullable="false"
                comment="Magento Quote ID"/>

        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false"
                default="0" comment="Store ID"/>

        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true"
                comment="Customer ID (NULL for guests)"/>

        <column xsi:type="varchar" name="customer_email" nullable="false" length="255"
                comment="Customer / Guest Email"/>

        <column xsi:type="varchar" name="customer_firstname" nullable="true" length="255"
                comment="Customer / Guest First Name"/>

        <column xsi:type="varchar" name="customer_lastname" nullable="true" length="255"
                comment="Customer / Guest Last Name"/>

        <column xsi:type="smallint" name="customer_group_id" unsigned="true" nullable="false"
                default="0" comment="Customer Group ID (0=NOT LOGGED IN)"/>

        <column xsi:type="int" name="items_count" unsigned="true" nullable="false"
                default="0" comment="Number of Items in Cart"/>

        <column xsi:type="int" name="items_qty" unsigned="true" nullable="false"
                default="0" comment="Total Quantity of Items"/>

        <column xsi:type="decimal" name="subtotal" scale="4" precision="20"
                nullable="false" default="0" comment="Cart Subtotal"/>

        <column xsi:type="decimal" name="grand_total" scale="4" precision="20"
                nullable="false" default="0" comment="Cart Grand Total"/>

        <column xsi:type="varchar" name="currency_code" nullable="false" length="3"
                comment="Currency Code (ISO-4217)"/>

        <column xsi:type="smallint" name="status" unsigned="true" nullable="false"
                default="1" comment="Status: 1=PENDING, 2=PROCESSING, 3=RECOVERED, 4=EXPIRED, 5=UNSUBSCRIBED"/>

        <column xsi:type="varchar" name="restore_token" nullable="false" length="64"
                comment="Unique Token for 1-Click Cart Restore Link"/>

        <column xsi:type="smallint" name="emails_sent" unsigned="true" nullable="false"
                default="0" comment="Count of Reminder Emails Sent"/>

        <column xsi:type="timestamp" name="last_email_sent_at" on_update="false"
                nullable="true" comment="Last Reminder Sent Timestamp"/>

        <column xsi:type="int" name="recovered_order_id" unsigned="true" nullable="true"
                comment="sales_order.entity_id if Recovered"/>

        <column xsi:type="decimal" name="recovered_revenue" scale="4" precision="20"
                nullable="true" comment="Revenue Captured on Recovery"/>

        <column xsi:type="timestamp" name="abandoned_at" on_update="false"
                nullable="false" default="CURRENT_TIMESTAMP" comment="When Cart Was Marked Abandoned"/>

        <column xsi:type="timestamp" name="recovered_at" on_update="false"
                nullable="true" comment="Recovery Timestamp"/>

        <column xsi:type="timestamp" name="created_at" on_update="false"
                nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>

        <column xsi:type="timestamp" name="updated_at" on_update="true"
                nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="ETECHFLOW_ABANDONED_CART_QUOTE_ID">
            <column name="quote_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="ETECHFLOW_ABANDONED_CART_RESTORE_TOKEN">
            <column name="restore_token"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_QUOTE_ID_QUOTE_ENTITY_ID"
                    table="etechflow_abandoned_cart" column="quote_id"
                    referenceTable="quote" referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_STORE_ID_STORE_STORE_ID"
                    table="etechflow_abandoned_cart" column="store_id"
                    referenceTable="store" referenceColumn="store_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="etechflow_abandoned_cart" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="SET NULL"/>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_RECOVERED_ORDER_ID_SALES_ORDER_ENTITY_ID"
                    table="etechflow_abandoned_cart" column="recovered_order_id"
                    referenceTable="sales_order" referenceColumn="entity_id"
                    onDelete="SET NULL"/>

        <index referenceId="ETECHFLOW_ABANDONED_CART_STATUS" indexType="btree">
            <column name="status"/>
        </index>

        <index referenceId="ETECHFLOW_ABANDONED_CART_CUSTOMER_EMAIL" indexType="btree">
            <column name="customer_email"/>
        </index>

        <index referenceId="ETECHFLOW_ABANDONED_CART_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>

        <index referenceId="ETECHFLOW_ABANDONED_CART_ABANDONED_AT" indexType="btree">
            <column name="abandoned_at"/>
        </index>

        <index referenceId="ETECHFLOW_ABANDONED_CART_STORE_STATUS_ABANDONED" indexType="btree">
            <column name="store_id"/>
            <column name="status"/>
            <column name="abandoned_at"/>
        </index>

    </table>

    <!-- ============================================================ -->
    <!-- TABLE 2: etechflow_abandoned_cart_rule                         -->
    <!-- ============================================================ -->
    <table name="etechflow_abandoned_cart_rule" resource="default" engine="innodb"
           comment="ETechFlow Abandoned Cart Email Rules">

        <column xsi:type="int" name="rule_id" unsigned="true" nullable="false"
                identity="true" comment="Primary Key"/>

        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="Rule Name (Admin)"/>

        <column xsi:type="text" name="description" nullable="true"
                comment="Rule Description (Admin)"/>

        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false"
                default="1" comment="1=Active, 0=Inactive"/>

        <column xsi:type="varchar" name="store_ids" nullable="false" length="255"
                default="0" comment="Comma-Separated Store IDs (0=All Stores)"/>

        <column xsi:type="varchar" name="customer_group_ids" nullable="false" length="255"
                default="0" comment="Comma-Separated Customer Group IDs (0=All)"/>

        <column xsi:type="int" name="send_after_minutes" unsigned="true" nullable="false"
                default="60" comment="Send Email After N Minutes of Cart Abandonment"/>

        <column xsi:type="smallint" name="sequence_number" unsigned="true" nullable="false"
                default="1" comment="1st, 2nd, 3rd reminder in a sequence"/>

        <column xsi:type="varchar" name="email_template" nullable="false" length="255"
                default="etechflow_abandoned_cart_default_template"
                comment="Email Template Identifier"/>

        <column xsi:type="varchar" name="email_sender" nullable="false" length="255"
                default="general" comment="Email Sender Identity (general, sales, support)"/>

        <column xsi:type="decimal" name="min_cart_subtotal" scale="4" precision="20"
                nullable="true" comment="Apply Only if Cart Subtotal >= This"/>

        <column xsi:type="decimal" name="max_cart_subtotal" scale="4" precision="20"
                nullable="true" comment="Apply Only if Cart Subtotal &lt;= This"/>

        <column xsi:type="text" name="conditions_serialized" nullable="true"
                comment="Magento Rule Conditions (JSON)"/>

        <column xsi:type="smallint" name="apply_to_guests" unsigned="true" nullable="false"
                default="1" comment="1=Send to Guest Carts, 0=Only Logged-in Customers"/>

        <column xsi:type="smallint" name="priority" unsigned="true" nullable="false"
                default="0" comment="Rule Priority (lower = first)"/>

        <column xsi:type="timestamp" name="created_at" on_update="false"
                nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>

        <column xsi:type="timestamp" name="updated_at" on_update="true"
                nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="rule_id"/>
        </constraint>

        <index referenceId="ETECHFLOW_AC_RULE_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>

        <index referenceId="ETECHFLOW_AC_RULE_PRIORITY" indexType="btree">
            <column name="priority"/>
        </index>

        <index referenceId="ETECHFLOW_AC_RULE_ACTIVE_PRIORITY_AFTER" indexType="btree">
            <column name="is_active"/>
            <column name="priority"/>
            <column name="send_after_minutes"/>
        </index>

    </table>

    <!-- ============================================================ -->
    <!-- TABLE 3: etechflow_abandoned_cart_email_log                    -->
    <!-- ============================================================ -->
    <table name="etechflow_abandoned_cart_email_log" resource="default" engine="innodb"
           comment="ETechFlow Abandoned Cart Email Send Log">

        <column xsi:type="int" name="log_id" unsigned="true" nullable="false"
                identity="true" comment="Primary Key"/>

        <column xsi:type="int" name="cart_id" unsigned="true" nullable="false"
                comment="FK to etechflow_abandoned_cart.entity_id"/>

        <column xsi:type="int" name="rule_id" unsigned="true" nullable="true"
                comment="FK to etechflow_abandoned_cart_rule.rule_id"/>

        <column xsi:type="varchar" name="recipient_email" nullable="false" length="255"
                comment="Email Recipient"/>

        <column xsi:type="varchar" name="email_template" nullable="false" length="255"
                comment="Template Used"/>

        <column xsi:type="smallint" name="sequence_number" unsigned="true" nullable="false"
                default="1" comment="Which Reminder (1st, 2nd, 3rd)"/>

        <column xsi:type="smallint" name="status" unsigned="true" nullable="false"
                default="1" comment="1=QUEUED, 2=SENT, 3=FAILED, 4=OPENED, 5=CLICKED, 6=CONVERTED"/>

        <column xsi:type="text" name="error_message" nullable="true"
                comment="Failure Reason (if status=FAILED)"/>

        <column xsi:type="timestamp" name="sent_at" on_update="false"
                nullable="true" comment="Sent Timestamp"/>

        <column xsi:type="timestamp" name="opened_at" on_update="false"
                nullable="true" comment="Opened Timestamp (via tracking pixel)"/>

        <column xsi:type="timestamp" name="clicked_at" on_update="false"
                nullable="true" comment="First Click Timestamp"/>

        <column xsi:type="smallint" name="open_count" unsigned="true" nullable="false"
                default="0" comment="Total Opens"/>

        <column xsi:type="smallint" name="click_count" unsigned="true" nullable="false"
                default="0" comment="Total Clicks"/>

        <column xsi:type="int" name="recovered_order_id" unsigned="true" nullable="true"
                comment="sales_order.entity_id if this Email led to Recovery"/>

        <column xsi:type="timestamp" name="created_at" on_update="false"
                nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="log_id"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_LOG_CART_ID_ABANDONED_CART_ENTITY_ID"
                    table="etechflow_abandoned_cart_email_log" column="cart_id"
                    referenceTable="etechflow_abandoned_cart" referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_LOG_RULE_ID_AC_RULE_RULE_ID"
                    table="etechflow_abandoned_cart_email_log" column="rule_id"
                    referenceTable="etechflow_abandoned_cart_rule" referenceColumn="rule_id"
                    onDelete="SET NULL"/>

        <constraint xsi:type="foreign"
                    referenceId="ETECHFLOW_AC_LOG_REC_ORDER_ID_SALES_ORDER_ENTITY_ID"
                    table="etechflow_abandoned_cart_email_log" column="recovered_order_id"
                    referenceTable="sales_order" referenceColumn="entity_id"
                    onDelete="SET NULL"/>

        <index referenceId="ETECHFLOW_AC_LOG_STATUS" indexType="btree">
            <column name="status"/>
        </index>

        <index referenceId="ETECHFLOW_AC_LOG_SENT_AT" indexType="btree">
            <column name="sent_at"/>
        </index>

        <index referenceId="ETECHFLOW_AC_LOG_CART_SEQUENCE" indexType="btree">
            <column name="cart_id"/>
            <column name="sequence_number"/>
        </index>

    </table>

</schema>
