<?xml version="1.0" encoding="UTF-8"?>
<!--
/**
 * Etechflow_AbandonedCart - Admin Carts grid UI Component.
 *
 * Renders the "Marketing > ETechFlow Abandoned Cart > Abandoned Carts"
 * page. Standard Magento UI Component grid:
 *   - Bookmarks toolbar (save/load custom views)
 *   - Columns selector
 *   - Filters bar
 *   - Paging
 *   - Per-row Actions column (View)
 *
 * Status column uses the Magento_Ui Select column with our CartStatus
 * source — labels render as text. Adding colored badges = Phase 21 perf
 * audit pass (custom column class with prepareDataSource).
 *
 * @category   ETechFlow
 * @package    Etechflow_AbandonedCart
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_abandonedcart_cart_listing.etechflow_abandonedcart_cart_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>etechflow_abandonedcart_cart_listing_columns</spinner>
        <deps>
            <dep>etechflow_abandonedcart_cart_listing.etechflow_abandonedcart_cart_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="etechflow_abandonedcart_cart_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Etechflow_AbandonedCart::carts</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="etechflow_abandonedcart_cart_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="etechflow_abandonedcart_cart_listing_columns">

        <column name="entity_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="customer_email" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>

        <column name="customer_firstname" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">First Name</label>
                <visible>false</visible>
            </settings>
        </column>

        <column name="customer_lastname" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Last Name</label>
                <visible>false</visible>
            </settings>
        </column>

        <column name="store_id" component="Magento_Ui/js/grid/columns/select" sortOrder="50">
            <settings>
                <options class="Magento\Store\Ui\Component\Listing\Column\Store\Options"/>
                <dataType>select</dataType>
                <filter>select</filter>
                <label translate="true">Store</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>

        <column name="items_count" sortOrder="60">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Items</label>
            </settings>
        </column>

        <column name="subtotal" class="Magento\Sales\Ui\Component\Listing\Column\Price" sortOrder="70">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Subtotal</label>
            </settings>
        </column>

        <column name="status" component="Magento_Ui/js/grid/columns/select" sortOrder="80">
            <settings>
                <options class="Etechflow\AbandonedCart\Model\Source\CartStatus"/>
                <dataType>select</dataType>
                <filter>select</filter>
                <label translate="true">Status</label>
            </settings>
        </column>

        <column name="emails_sent" sortOrder="90">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Emails Sent</label>
            </settings>
        </column>

        <column name="abandoned_at" class="Magento\Ui\Component\Listing\Columns\Date" sortOrder="100">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Abandoned At</label>
            </settings>
        </column>

        <column name="recovered_at" class="Magento\Ui\Component\Listing\Columns\Date" sortOrder="110">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Recovered At</label>
            </settings>
        </column>

        <actionsColumn name="actions"
                       class="Etechflow\AbandonedCart\Ui\Component\Listing\Column\CartActions"
                       sortOrder="200">
            <settings>
                <indexField>entity_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>120</resizeDefaultWidth>
            </settings>
        </actionsColumn>

    </columns>

</listing>
