<script>
    function etfShowForm(plan, label, priceText) {
        document.getElementById('etf-plan-input').value = plan;
        document.getElementById('etf-plan-summary').textContent = label + ' — ' + priceText;
        var form = document.getElementById('etf-checkout-form');
        form.classList.add('show');
        form.scrollIntoView({behavior: 'smooth', block: 'center'});
        document.getElementById('etf-name').focus();
    }
    function etfHideForm() {
        document.getElementById('etf-checkout-form').classList.remove('show');
    }
</script>
