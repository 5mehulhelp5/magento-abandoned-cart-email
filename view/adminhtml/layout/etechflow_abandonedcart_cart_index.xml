<?xml version="1.0"?>
<!--
/**
 * Etechflow_AbandonedCart - Admin Carts grid layout.
 *
 * Embeds the etechflow_abandonedcart_cart_listing UI Component into the
 * standard admin content container. UI Component XML handles everything
 * downstream (columns, filters, paging, data binding).
 *
 * @category   ETechFlow
 * @package    Etechflow_AbandonedCart
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <uiComponent name="etechflow_abandonedcart_cart_listing"/>
        </referenceContainer>
    </body>
</page>
